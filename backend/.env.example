# ─── Backend environment variables ─────────────────────────────────────────────
#
# IMPORTANT: Set these in Render → Environment → Environment Variables.
# Do NOT commit the real values to git; this file is only a reference template.
#

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# A strong random string for signing JWTs (min 32 chars recommended)
JWT_SECRET=your_super_secret_jwt_key_here

# Port Render will inject automatically — keep 5000 as local default
PORT=5000

# Comma-separated list of allowed frontend origins.
# Add your Netlify URL here (no trailing slash):
#   e.g. CLIENT_URL=https://devnotes.netlify.app
# Any *.netlify.app origin is also allowed automatically by server.js.
CLIENT_URL=https://your-netlify-site.netlify.app

# Google Gemini API key (for AI features)
GEMINI_API_KEY=your_gemini_api_key_here
